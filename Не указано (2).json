{"entites":[{"id":6084,"pos_start":44009,"pos_end":44011,"node_uri":"http://erlangen-crm.org/mainOntology/b240f8f0-75b7-4e5f-ad32-b89e0961e2ca/a0ceef3c-7417-41b3-bca7-26f840ded79e","markup":261,"node":{"id":"http://erlangen-crm.org/mainOntology/b240f8f0-75b7-4e5f-ad32-b89e0961e2ca/a0ceef3c-7417-41b3-bca7-26f840ded79e","position":{"x":0,"y":0},"type":"mainNode","data":{"id":"4:22bf3666-b797-44f3-ab4f-ae4db1676bd4:6460","labels":["http://www.w3.org/2002/07/owl#NamedIndividual","http://erlangen-crm.org/mainOntology/b240f8f0-75b7-4e5f-ad32-b89e0961e2ca","http://erlangen-crm.org/mainOntology/b240f8f0-75b7-4e5f-ad32-b89e0961e2ca/e21f77bf-5fcd-498f-b9d2-f0973de2fbd9"],"params":["http://www.w3.org/2000/01/rdf-schema#comment","http://www.w3.org/2000/01/rdf-schema#label","uri"],"http://www.w3.org/2000/01/rdf-schema#label":["Проксима Центавра b@ru","Name@en"],"uri":"http://erlangen-crm.org/mainOntology/b240f8f0-75b7-4e5f-ad32-b89e0961e2ca/a0ceef3c-7417-41b3-bca7-26f840ded79e","ontology_uri":null,"is_toggled":false,"toggled_data":[],"params_values":{"http://www.w3.org/2000/01/rdf-schema#comment":"Описание","http://www.w3.org/2000/01/rdf-schema#label":["Проксима Центавра b@ru","Name@en"],"uri":"http://erlangen-crm.org/mainOntology/b240f8f0-75b7-4e5f-ad32-b89e0961e2ca/a0ceef3c-7417-41b3-bca7-26f840ded79e"},"file":null,"connected_file":null,"text_mentions":[{"pos_start":44009,"pos_end":44011,"markup":261,"original_object_uri":"http://erlangen-crm.org/mainResource/e85e8d71-4159-4ad0-8f09-eaf78310e376/5e5d77d8-2e95-4dc8-bc67-1ced4fecf9f1"}]}}},{"id":6085,"pos_start":44017,"pos_end":44018,"node_uri":"http://erlangen-crm.org/mainOntology/b240f8f0-75b7-4e5f-ad32-b89e0961e2ca/633ac892-a118-4162-a7be-6df69b4c7bd1","markup":261,"node":{"id":"http://erlangen-crm.org/mainOntology/b240f8f0-75b7-4e5f-ad32-b89e0961e2ca/633ac892-a118-4162-a7be-6df69b4c7bd1","position":{"x":0,"y":0},"type":"mainNode","data":{"id":"4:22bf3666-b797-44f3-ab4f-ae4db1676bd4:6443","labels":["http://www.w3.org/2002/07/