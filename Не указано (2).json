9-eaf78310e376/5e5d77d8-2e95-4dc8-bc67-1ced4fecf9f1"}]}}},{"id":6089,"pos_start":11008,"pos_end":11012,"node_uri":"http://erlangen-crm.org/mainOntology/b240f8f0-75b7-4e5f-ad32-b89e0961e2ca/7fc2c4f7-23c2-4430-8cb1-00de57915e23","markup":261,"node":{"id":"http://erlangen-crm.org/mainOntology/b240f8f0-75b7-4e5f-ad32-b89e0961e2ca/7fc2c4f7-23c2-4430-8cb1-00de57915e23","position":{"x":0,"y":0},"type":"mainNode","data":{"id":"4:22bf3666-b797-44f3-ab4f-ae4db1676bd4:5920","labels":["http://erlangen-crm.org/mainOntology/b240f8f0-75b7-4e5f-ad32-b89e0961e2ca","http://www.w3.org/2002/07/owl#ObjectProperty"],"params":["http://www.w3.org/2000/01/rdf-schema#label","uri"],"http://www.w3.org/2000/01/rdf-schema#label":["Состоит из@ru","Consists of@en"],"uri":"http://erlangen-crm.org/mainOntology/b240f8f0-75b7-4e5f-ad32-b89e0961e2ca/7fc2c4f7-23c2-4430-8cb1-00de57915e23","ontology_uri":null,"is_toggled":false,"toggled_data":[],"params_values":{"http://www.w3.org/2000/01/rdf-schema#label":["Состоит из@ru","Consists of@en"],"uri":"http://erlangen-crm.org/mainOntology/b240f8f0-75b7-4e5f-ad32-b89e0961e2ca/7fc2c4f7-23c2-4430-8cb1-00de57915e23"},"file":null,"connected_file":null,"text_mentions":[{"pos_start":11008,"pos_end":11012,"markup":261,"original_object_uri":"http://erlangen-crm.org/mainResource/e85e8d71-4159-4ad0-8f09-eaf78310e376/5e5d77d8-2e95-4dc8-bc67-1ced4fecf9f1"}]}}}],"relations":[{"id":823,"start":6084,"end":6085,"connection":6086,"markup":261},{"id":825,"start":6087,"end":6088,"connection":6089,"markup":261}],"originalText":["ТЕМА: ПРОКСИМА ЦЕНТАВРА (Красный Карлик)","================================================================================","","────────────────────────────────────────────────────────────────────────────────","Источник: nplus1.ru — «Проксима Центавра произвела экстремально мощную вспышку»","URL: https://nplus1.ru/news/2021/04/26/flare-proxima","Дата: 26 апреля 2021","────────────────────────────────────────────────────────────────────────────────","","Астрономы зарегистрировали рекордно мощную вспышку на ближайшей к Солнцу звезде — Проксиме Центавра. Она не только не вписывается в текущие теоретические модели, но и вынуждает учёных пересмотреть возможность обитаемости экзопланет, обращающихся вокруг Проксимы. Статья опубликована в The Astrophysical Journal Letters.","","Проблема обитаемости экзопланет у красных карликов, которые являются наиболее распространённым типом звёзд в Млечном Пути, уже долгое время занимает умы астрономов. С одной стороны, у таких звёзд часто обнаруживаются экзопланеты, похожие на Землю, которые находятся в обитаемой зоне. В то же время многие красные карлики, особенно молодые, демонстрируют мощные вспышки и корональные выбросы массы, которые способны негативно повлиять на атмосферы экзопланет.","","Система Проксимы Центавра представляет для астрономов наибольший интерес, так как этот красный карлик — самая близкая к Земле звезда (не считая Солнца), кроме того, она обладает двумя экзопланетами, одна из которых землеподобная и находится в зоне обитаемости.","","Однако в 2017 году Проксима Центавра произвела очень мощную вспышку, которая увеличила яркость звезды в тысячу раз, что делает этот красный карлик природной лабораторией для учёных, занимающихся исследованием влияния звёздной активности и ветров на экзопланеты.","","Астрономы намерены продолжить наблюдения за Проксимой, так как уже полученные данные не только ставят под сомнение текущие теоретические модели вспышек звёзд, но и заставляют пересмотреть наши представления об обитаемости экзопланет у красных карликов.","","","────────────────────────────────────────────────────────────────────────────────","Источник: nplus1.ru — «Ближайшая экзопланета оказалась не транзитной»","URL: https://nplus1.ru/news/2019/05/07/no-transit-proxima","Дата: 7 мая 2019","────────────────────────────────────────────────────────────────────────────────","","Проксима Центавра — это ближайшая к Земле звезда, не считая Солнца, она расположена на расстоянии 1,3 парсека. Вместе с двумя компаньонами она образует тройную систему Альфа Центавра. Проксима представляет собой небольшое светило из класса красных карликов, по массе она в 8 раз меньше Солнца, а по светимости уступает ему почти в 600 раз.","","В то же время, на больших длинах волн вспышки проявляются гораздо слабее и светимость звезды намного постояннее. Новые наблюдения, суммарно длившиеся около 48 часов, оказались несовместимы с наличием транзитной экзопланеты: со стандартной точностью Проксиму Центавра не затмевает короткопериодическая планета с радиусом более 0,4 земного.","","Экзопланета, получившая название Проксима Центавра b, потенциально является исключительно интересным для астрономии объектом, ведь она не только ближайшее к нам подобное тело, но и по оценкам некоторых параметров примерно соответствует Земле. Например, исходя из светимости звезды, планета должна находиться в зоне обитаемости, то есть равновесная температура на её поверхности допускает наличие жидкой воды. Масса планеты по первичным оценкам также была сопоставима с земной.","","","────────────────────────────────────────────────────────────────────────────────","Источник: inscience.news — «Ad astra: Проксима Центавра — увидеть и умереть»","URL: https://inscience.news/ru/article/world-science/astronomy/9800","────────────────────────────────────────────────────────────────────────────────","","В Центавре, созвездии Южного полушария, находится ближайшая (до неё всего четыре световых года) к Солнцу звезда Проксима Центавра (α Центавра С). Этот невидимый невооружённым глазом красный карлик соседствует с солнцеподобными звёздами α Центавра А и α Центавра B. Эти двое с Земли видны как одна звезда, причём третья по яркости (после Сириуса и Канопуса).","","Проксима Центавра гораздо меньше и нашего Солнца, и своих соседей.","","В мае 2019 года сразу пять обсерваторий на Земле и в космосе зарегистрировали вспышку, во время которой светимость звезды в УФ-диапазоне увеличилась в 14 тысяч раз. Даже самая мощная вспышка на нашем Солнце была в 100 раз слабее. Заметное излучение от звезды исходит и в рентгеновском диапазоне. А в 2017 году радиотелескоп ALMA обнаружил в окрестностях Проксимы Центавра три пояса из астероидов и пыли. Похожие есть и в Солнечной системе, например пояс Койпера.","","Ещё одно общее обнаружилось в 2016 году — экзопланета Проксима Центавра b, вращающаяся вокруг красного карлика Проксимы Центавра.","","Так как Проксима Центавра — красный карлик, любая планета в её окрестностях будет повёрнута к ней всегда одной и той же стороной. Это явление называется приливным захватом (или замыканием), и оно сильно осложнило бы жизнь на Проксиме Центавра b. Ведь одна сторона вечно холодная, другая — под постоянной атакой звёздного излучения.","","Осложняют ситуацию и мощные вспышки звезды. Спасти от ультрафиолета и рентгена могла бы плотная атмосфера вкупе с магнитным полем, примерно как на Земле. Но атмосфера постоянно истощалась бы от звёздного ветра, а при слабом магнитном поле мощная вспышка звезды сдула бы атмосферу вместе со всеми живыми организмами в ней.","","","────────────────────────────────────────────────────────────────────────────────","Источник: lenta.ru — «У ближайшей к Солнцу звезды открыли \"вторую Землю\"»","URL: https://lenta.ru/articles/2016/08/25/proximacentauri/","Дата: 25 августа 2016","────────────────────────────────────────────────────────────────────────────────","","Астрономы обнаружили потенциально обитаемую планету у Проксимы Центавра — самой близкой к Солнцу звезды.","","Красные карлики — одни из самых активных звёзд во Вселенной. Рентгеновская вспышка, генерируемая Проксимой Центавра, примерно в 400 раз сильнее самой интенсивной солнечной вспышки.","","Расстояние от нас до Проксимы Центавра — 4,24 световых года. Астрономы давно подозревали, что в её окрестностях есть землеподобная планета. На это указывало компьютерное моделирование. К тому же больше всего экзопланет обнаружено именно у красных карликов. Открытие Proxima b было совершено посредством наблюдения доплеровского смещения спектра звезды, обусловленного гравитационным воздействием планеты. Работа выполнена на двух научных инструментах Европейской южной обсерватории — HARPS и UVES.","","Хотя Proxima b близко расположена к светилу, она может быть обитаемой. Это объясняется природой красных карликов. Температура поверхности Проксимы Центавра более чем в два раза (почти на три тысячи кельвинов), масса — в десять раз, а светимость — на четыре порядка меньше, чем у Солнца. Такая комбинация параметров означает, что землеподобная планета должна располагаться намного ближе к звезде, чем Земля к Солнцу.","","Рассчитанный для Проксимы Центавра интервал обитаемости приходится на расстояния от 0,04 до 0,08 астрономической единицы от красного карлика. Небесное тело при этом должно делать полный оборот вокруг светила за 9,1–24,5 дня. Proxima b отвечает этим критериям, значит, на ней может быть жидкая вода, и, вероятно, существуют пригодные для жизни условия.","","","────────────────────────────────────────────────────────────────────────────────","Источник: o-kosmose.com — «Проксима Центавра: описание, характеристики, планеты системы»","URL: https://o-kosmose.com/glubokiy-kosmos/proksima-tsentavra","────────────────────────────────────────────────────────────────────────────────","","Несмотря на малое расстояние до Земли, видимая звёздная величина Проксимы Центавра составляет 11m. Эту звезду нельзя разглядеть с поверхности нашей планеты невооружённым глазом, поскольку её свет слишком слаб.","","Проксима относится к разряду красных карликов или М-карликов. Она — одна из самых маленьких звёзд в космическом пространстве. Будь она ещё чуть меньше, и водород в её ядре не смог бы превращаться в гелий, а сама звезда относилась бы к разряду «коричневых карликов».","","В 1951 году американский астроном Харлоу Шепли сравнил фотографии Проксимы Центавра, сделанные за продолжительный период, и заметил, что примерно на 8% изображений звезда демонстрирует некоторое увеличение яркости.","","Проксима Центавра — это красный карлик. Звёзды данного типа сжигают топливо настолько медленно, что продолжительность их жизни достигает 100 млрд лет. Для сравнения: полный жизненный цикл Солнца по предположению учёных составит всего лишь 12 млрд лет.","","Векторы движения Проксимы Центавры совпадают с векторами движения звёзд Альфа Центавра А и Альфа Центавра В. Следовательно, эти три звезды образуют единую систему, причём Проксима Центавра обращается по орбите вокруг пары А и В.","",""],"textWithIds":{"0":"ТЕМА:","1":"ПРОКСИМА","2":"ЦЕНТАВРА","3":"(Красный","4":"Карлик)","1000":"================================================================================","2000":"","3000":"────────────────────────────────────────────────────────────────────────────────","4000":"Источник:","4001":"nplus1","4002":".","4003":"ru","4004":"—","4005":"«Проксима","4006":"Центавра","4007":"произвела","4008":"экстремально","4009":"мощную","4010":"вспышку»","5000":"URL:","5001":"https://nplus1","5002":".","5003":"ru/news/2021/04/26/flare-proxima","6000":"Дата:","6001":"26","6002":"апреля","6003":"2021","7000":"────────────────────────────────────────────────────────────────────────────────","8000":"","9000":"Астрономы","9001":"зарегистрировали","9002":"рекордно","9003":"мощную","9004":"вспышку","9005":"на","9006":"ближайшей","9007":"к","9008":"Солнцу","9009":"звезде","9010":"—","9011":"Проксиме","9012":"Центавра","9013":". ","9014":"Она","9015":"не","9016":"только","9017":"не","9018":"вписывается","9019":"в","9020":"текущие","9021":"теоретические","9022":"модели","9023":", ","9024":"но","9025":"и","9026":"вынуждает","9027":"учёных","9028":"пересмотреть","9029":"возможность","9030":"обитаемости","9031":"экзопланет","9032":", ","9033":"обращающихся","9034":"вокруг","9035":"Проксимы","9036":". ","9037":"Статья","9038":"опубликована","9039":"в","9040":"The","9041":"Astrophysical","9042":"Journal","9043":"Letters","9044":".","9045":"","10000":"","11000